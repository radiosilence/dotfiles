#!/usr/bin/env bash
# Worktree picker for Zellij keybinding
# Enter: open in tab | Ctrl-X: remove | Ctrl-B: open PR in browser
# Type a new name to create from origin/main
set -euo pipefail

preview="$HOME/.dotfiles/scripts/wt-preview {1}"

root=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)
root="${root%/.git}"

base_ref=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null || echo "refs/remotes/origin/main")
base="${base_ref##refs/remotes/origin/}"

output=$(git worktree list --porcelain 2>/dev/null \
  | awk '/^worktree /{ path=$2 } /^branch /{ branch=$2; sub("refs/heads/","",branch); printf "%s\t%s\n", branch, path }' \
  | fzf --ansi --reverse --delimiter=$'\t' --with-nth=1 \
         --header="worktrees" \
         --border --border-label=" enter: open tab · ctrl-x: rm · ctrl-b: pr browser " --border-label-pos=bottom \
         --preview "$preview" --preview-window='right:70%' \
         --print-query --expect='ctrl-x,ctrl-b'
) || true

query=$(echo "$output" | sed -n '1p')
key=$(echo "$output" | sed -n '2p')
selected=$(echo "$output" | sed -n '3p')

# Resolve name: selected item wins, fall back to query
if [[ -n $selected ]]; then
  name=$(echo "$selected" | cut -f1)
else
  name="$query"
fi

[[ -n $name ]] || exit 0

# Resolve worktree path
wt=$(git worktree list --porcelain 2>/dev/null \
  | awk -v b="refs/heads/$name" '/^worktree /{ wt=$2 } /^branch /{ if($2==b) print wt }')

case "$key" in
  ctrl-x)
    if [[ -z $wt ]]; then
      echo "no worktree for $name" >&2
      sleep 1
      exit 1
    fi
    git worktree remove "$wt" && git branch -d "$name" 2>/dev/null
    echo "removed: $name"
    sleep 1
    ;;

  ctrl-b)
    if command -v gh >/dev/null; then
      gh pr view "$name" --web 2>/dev/null || echo "no PR for $name" >&2
    fi
    sleep 1
    ;;

  *) # Enter — open/create
    if [[ -z $wt ]]; then
      wt="$root/.worktrees/$name"
      mkdir -p "$root/.worktrees"
      [[ -f "$root/.worktrees/.gitignore" ]] || echo '*' > "$root/.worktrees/.gitignore"
      git fetch origin "$base" --quiet || exit 1
      git worktree add "$wt" -b "$name" "origin/$base" || exit 1
    fi

    if zellij action query-tab-names 2>/dev/null | grep -qxF "$name"; then
      zellij action go-to-tab-name "$name"
    else
      zellij action new-tab --name "$name" --cwd "$wt" --close-on-exit -- zsh
    fi
    ;;
esac
