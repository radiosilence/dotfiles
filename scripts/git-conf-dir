#!/usr/bin/env bash
set -euo pipefail

key="${1:?Usage: git conf-dir <key> <value> (e.g. git conf-dir user.email me@work.com)}"
value="${2:?Usage: git conf-dir <key> <value>}"

# Use the git toplevel's parent as the includeIf dir, falling back to cwd
if git_root=$(git rev-parse --show-toplevel 2>/dev/null); then
  dir=$(dirname "$git_root")
else
  dir=$(pwd)
fi

# Ensure trailing slash for gitdir matching
[[ "$dir" == */ ]] || dir="$dir/"

# Derive conf name from path: ~/workspace/surgeventures -> workspace--surgeventures
rel_dir="${dir/#$HOME\//}"
rel_dir="${rel_dir%/}"
name="${rel_dir//\//--}"
mkdir -p "$HOME/.local/git.d"
conf_file="$HOME/.local/git.d/${name}.conf"

# Clean up old locations (migration from previous naming)
old_basename=$(basename "${dir%/}")
for old in "$HOME/.git.${old_basename}.conf" "$HOME/.local/git.d/${old_basename}.conf"; do
  if [ -f "$old" ] && [ "$old" != "$conf_file" ]; then
    rm "$old"
    printf "  \033[33m→\033[0m %s (migrated)\n" "$old"
  fi
done

# Upsert the key in the conf file
git config --file "$conf_file" "$key" "$value"
printf "  \033[32m󰄬\033[0m %s = %s in %s\n" "$key" "$value" "$conf_file"

# Upsert includeIf in ~/.gitconfig
gitconfig="$HOME/.gitconfig"
[ -f "$gitconfig" ] || touch "$gitconfig"

short_dir="${dir/#$HOME/~}"
short_conf="${conf_file/#$HOME/~}"
include_pattern="gitdir:${short_dir}"

if grep -qF "$include_pattern" "$gitconfig" 2>/dev/null; then
  sed -i '' "/\[includeIf \"gitdir:${short_dir//\//\\/}\"\]/{n;s|path = .*|path = ${short_conf}|;}" "$gitconfig"
  printf "  \033[32m󰄬\033[0m includeIf updated in %s\n" "$gitconfig"
else
  printf '\n[includeIf "gitdir:%s"]\npath = %s\n' "$short_dir" "$short_conf" >> "$gitconfig"
  printf "  \033[32m󰄬\033[0m includeIf added to %s\n" "$gitconfig"
fi
