#!/usr/bin/env bash
# Wrapper shell for worktree tabs — offers cleanup on exit
# Args: $1 = worktree path, $2 = branch name
set -euo pipefail

wt="$1"
name="$2"

# Colors
dim=$'\033[2m'
bold=$'\033[1m'
yellow=$'\033[1;33m'
green=$'\033[1;32m'
red=$'\033[1;31m'
reset=$'\033[0m'

# Run interactive shell
zsh -i || true

# Guard: never offer to remove the main worktree
root=$(git -C "$wt" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)
root="${root%/.git}"

if [[ "$wt" == "$root" ]]; then
  exit 0
fi

# Cleanup prompt
echo ""
echo "${yellow}━━━ worktree: ${bold}${name}${reset}${yellow} ━━━${reset}"
echo ""
echo "  ${dim}path:${reset}   $wt"
echo "  ${dim}branch:${reset} $name"
echo ""
printf "${bold}  remove worktree + branch? ${dim}[y/N]${reset} "
read -rsn1 answer
echo ""
echo ""

if [[ $answer == [yY] ]]; then
  if git worktree remove "$wt" 2>/dev/null; then
    git branch -d "$name" 2>/dev/null
    echo "  ${green}✓${reset} removed ${bold}${name}${reset}"
  else
    echo "  ${red}✗${reset} failed to remove ${dim}(dirty worktree?)${reset}"
    echo "  ${dim}use ${reset}git worktree remove --force${dim} to force${reset}"
    sleep 2
  fi
else
  echo "  ${dim}kept ${name}${reset}"
fi
sleep 0.5
