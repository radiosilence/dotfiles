#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "-n" || "${1:-}" == "--dry-run" ]]; then
  printf "  \033[36m→\033[0m Dry run - would execute:\n"
  printf "  \033[36m→\033[0m   git commit --amend --no-edit\n"
  printf "  \033[36m→\033[0m   git push --force\n"
  exit 0
fi

git commit --amend --no-edit && git push --force && printf "  \033[32m󰄬\033[0m CI/CD triggered\n"
