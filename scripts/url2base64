#!/usr/bin/env bash
set -euo pipefail

mime="image/svg+xml"
timeout=30

while [[ $# -gt 0 ]]; do
  case "$1" in
    -t|--mime-type) mime="$2"; shift 2 ;;
    --timeout) timeout="$2"; shift 2 ;;
    -h|--help)
      echo "Usage: url2base64 [-t MIME_TYPE] [--timeout SECS] URL"
      echo "Convert URL content to base64 data URL (default MIME: image/svg+xml)"
      exit 0 ;;
    *) url="$1"; shift ;;
  esac
done

if [[ -z "${url:-}" ]]; then
  echo "Usage: url2base64 [-t MIME_TYPE] [--timeout SECS] URL" >&2
  exit 1
fi

encoded=$(curl -sfL --max-time "$timeout" "$url" | base64)
printf 'data:%s;base64,%s' "$mime" "$encoded"
