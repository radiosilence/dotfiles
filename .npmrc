# auth token for npmjs.org, pulled from env (never hardcode this shit)
//registry.npmjs.org/:_authToken=${NPM_AUTH_TOKEN}

# block pre/post/install lifecycle scripts — primary defence against
# supply-chain worms (shai-hulud etc) that pwn you the moment you `npm i`
ignore-scripts=true

# refuse packages published less than 10080 minutes (7 days) ago —
# gives the ecosystem time to spot a compromised release before it lands
minimum-release-age=10080

# verify registry signatures on install; bails if a package was tampered with
audit-signatures=true

# kill the "N packages are looking for funding" nag
fund=false

# pin exact versions on `npm install --save` — no sneaky ^/~ drift
save-exact=true
