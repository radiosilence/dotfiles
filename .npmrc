# npm-only config. pnpm 10+ moved its non-auth settings to
# ~/.config/pnpm/config.yaml — see there for pnpm-specific hardening.

# block pre/post/install lifecycle scripts — primary defence against
# supply-chain worms (shai-hulud etc) that pwn you the moment you `npm i`
ignore-scripts=true

# kill the "N packages are looking for funding" nag
fund=false

# pin exact versions on `npm install --save` — no sneaky ^/~ drift
save-exact=true

# registry auth via env indirection — no token literal on disk. ${NPM_AUTH_TOKEN}
# is a standing, read-only npmjs token exported by mise from the gitignored
# ~/.config/mise/conf.d/secrets.toml. Empty/unset just falls back to anonymous
# reads. RO scope keeps blast radius ~nil if the env ever leaks.
//registry.npmjs.org/:_authToken=${NPM_AUTH_TOKEN}
