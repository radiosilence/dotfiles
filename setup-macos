#!/usr/bin/env bash
# Bootstrap script — run this on a fresh macOS system
# Usage: curl -fsSL https://raw.githubusercontent.com/radiosilence/dotfiles/main/setup-macos | bash
set -e

tmpdir=$(mktemp -d)
trap "rm -rf '$tmpdir'" EXIT

printf "\n  \033[1m\033[35m⟢\033[0m \033[1mdotfiles bootstrap\033[0m\n\n"

# Get go-task + Taskfile — no git, no xcode, just curl
curl -fsSL https://taskfile.dev/install.sh | sh -s -- -b "$tmpdir" 2>/dev/null
curl -fsSL https://raw.githubusercontent.com/radiosilence/dotfiles/main/Taskfile.yml -o "$tmpdir/Taskfile.yml"

printf "  \033[32m󰄬\033[0m bootstrap ready — handing off to Taskfile\n\n"

# Let the DAG handle everything
"$tmpdir/task" --taskfile "$tmpdir/Taskfile.yml" converge
