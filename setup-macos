#!/usr/bin/env zsh
# Bootstrap script - run this on a fresh system
# Usage: curl -fsSL https://raw.githubusercontent.com/radiosilence/dotfiles/main/setup-macos | zsh

set -e

# --- Xcode Command Line Tools (needed for git, compilers, etc.) ---
if xcode-select -p &>/dev/null; then
  printf "\033[32m  ok xcode cli tools\033[0m\n"
else
  printf "\033[33m  -> installing xcode command line tools...\033[0m\n"
  xcode-select --install
  printf "\033[33m  -> waiting for xcode cli tools installation to complete...\033[0m\n"
  printf "\033[33m  -> press enter when the installer finishes...\033[0m"
  read -r </dev/tty
fi

# --- Clone dotfiles ---
DOTFILES_DIR="$HOME/.dotfiles"
if [[ -d "$DOTFILES_DIR/.git" ]]; then
  printf "\033[32m  ok dotfiles repo\033[0m\n"
  (cd "$DOTFILES_DIR"; git pull)
else
  printf "\033[33m  -> cloning dotfiles...\033[0m\n"
  git clone https://github.com/radiosilence/dotfiles "$DOTFILES_DIR"
  printf "\033[32m  ok dotfiles cloned\033[0m\n"
fi

cd "$DOTFILES_DIR"

printf "\033[1m/// .DOTFILES BOOTSTRAP\033[0m\n\n"

# --- dotfiles.toml hint ---
printf "\033[32m  ok\033[0m dotfiles.toml (local overrides: dotfiles.local.toml)\n"

# --- Sudo setup (first, so the session carries through the rest) ---
SUDO_LOCAL="/etc/pam.d/sudo_local"
if [[ -f "$SUDO_LOCAL" ]] && grep -q pam_tid "$SUDO_LOCAL"; then
  printf "\033[32m  ok touchid sudo\033[0m\n"
else
  printf "\033[33m  -> enabling touchid for sudo...\033[0m\n"
  sudo sh -c 'echo "auth       sufficient     pam_tid.so" > /etc/pam.d/sudo_local'
  printf "\033[32m  ok touchid sudo\033[0m\n"
fi

SUDO_TIMEOUT="/etc/sudoers.d/timeout"
if [[ -f "$SUDO_TIMEOUT" ]]; then
  printf "\033[32m  ok sudo timeout\033[0m\n"
else
  printf "\033[33m  -> setting sudo timeout to 30 min...\033[0m\n"
  sudo sh -c 'echo "Defaults timestamp_timeout=30" > /etc/sudoers.d/timeout && chmod 0440 /etc/sudoers.d/timeout'
  printf "\033[32m  ok sudo timeout\033[0m\n"
fi

# --- Homebrew ---
if (($+commands[brew])); then
  printf "\033[32m  ok homebrew\033[0m\n"
else
  printf "\033[33m  -> installing homebrew...\033[0m\n"
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  if [[ -d /opt/homebrew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  else
    eval "$(/usr/local/bin/brew shellenv)"
  fi
  printf "\033[32m  ok homebrew installed\033[0m\n"
fi

# --- Brewfile roles ---
ROLES_FILE="$DOTFILES_DIR/dotfiles-roles.yml"
if [[ -f "$ROLES_FILE" ]]; then
  printf "\033[32m  ok dotfiles-roles.yml\033[0m\n"
else
  cp "$DOTFILES_DIR/dotfiles-roles.yml.template" "$ROLES_FILE"
  printf "\033[33m  -> copied dotfiles-roles.yml.template to dotfiles-roles.yml\033[0m\n"
  printf "\033[33m  -> edit dotfiles-roles.yml to enable brew roles...\033[0m"
fi

# --- brew bundle ---
printf "\n\033[1m/// .BREW BUNDLE\033[0m\n\n"
brew bundle --file="$DOTFILES_DIR/Brewfile" --quiet || true

# --- 1Password setup (SSH agent needed for git/mise) ---
printf "\n\033[1m/// .1PASSWORD\033[0m\n\n"
printf "\033[33m  -> open 1Password, sign in, and enable the SSH agent:\033[0m\n"
printf "\033[36m     Settings -> Developer -> SSH Agent\033[0m\n"
printf "\033[33m  -> press enter when done...\033[0m"
read -r </dev/tty
printf "\033[32m  ok 1password\033[0m\n"

# --- GitHub CLI auth (needed for mise to install private/github tools) ---
if (($+commands[gh])); then
  if ! gh auth status &>/dev/null; then
    printf "\n\033[1m/// .GITHUB AUTH\033[0m\n\n"
    printf "\033[33m  -> gh is not authenticated. open a new tab and run:\033[0m\n"
    printf "\033[36m     gh auth login\033[0m\n"
    printf "\033[33m  -> press enter when done...\033[0m"
    read -r </dev/tty
  fi
  if gh auth status &>/dev/null; then
    printf "\033[32m  ok gh authenticated\033[0m\n"
    export GITHUB_TOKEN="$(gh auth token)"
  else
    printf "\033[33m  !! gh still not authenticated, mise install may fail for github tools\033[0m\n"
  fi
fi

# --- mise tools ---
if (($+commands[mise])); then
  printf "\n\033[1m/// .MISE TOOLS\033[0m\n\n"
  export PATH="$HOME/.local/share/mise/shims:$PATH"
  printf "\033[33m  -> mise install...\033[0m\n"
  mise install
  printf "\033[32m  ok mise tools\033[0m\n"
else
  printf "\033[31m  !! mise not found after brew bundle - check Brewfile\033[0m\n"
  exit 1
fi

# --- Link dotfiles (before anything that depends on shell config) ---
printf "\n\033[1m/// .LINK\033[0m\n\n"
mise run link

# --- Rosetta 2 (Apple Silicon only) ---
if [[ "$(uname -m)" == "arm64" ]]; then
  if /usr/bin/pgrep -q oahd 2>/dev/null; then
    printf "\033[32m  ok rosetta 2\033[0m\n"
  else
    printf "\033[33m  -> installing rosetta 2...\033[0m\n"
    /usr/sbin/softwareupdate --install-rosetta --agree-to-license
    printf "\033[32m  ok rosetta 2 installed\033[0m\n"
  fi
fi

# Re-exec remaining setup in a fresh login shell so linked config is active
exec zsh -l -c "
  # Install Claude Code if missing
  if ! command -v claude &>/dev/null; then
    printf '\n\033[1m/// .CLAUDE CODE\033[0m\n\n'
    curl -fsSL https://claude.ai/install.sh | bash
  fi
  printf '\n\033[1m/// .BUILD\033[0m\n\n'
  mise run reinstall-bins
  printf '\n'
  ~/.dotfiles/bin/upd

  # Switch repo to SSH now that everything is set up
  printf '\n\033[1m/// .FINALIZE\033[0m\n\n'
  mise run use-ssh

  printf '\n\033[32m  ok setup complete. restart your terminal.\033[0m\n\n'
"
