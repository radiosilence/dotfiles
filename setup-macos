#!/usr/bin/env zsh
# Bootstrap script — run this on a fresh macOS system.
# Usage: curl -fsSL https://raw.githubusercontent.com/radiosilence/dotfiles/main/setup-macos | zsh
#
# Sequential, interactive bootstrap. Each step blocks until done so brew's
# sudo prompts, GitHub auth, and 1Password's manual setup can't race the
# pipeline. Once this finishes, `task converge` parallelises everything else.
set -e

DOTFILES="${DOTFILES:-$HOME/.dotfiles}"

OK=$'\033[32m󰄬\033[0m'
WARN=$'\033[33m\033[0m'
WORK=$'\033[35m󱁤\033[0m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

print -P "\n  ${BOLD}\033[35m⟢${RESET} ${BOLD}dotfiles bootstrap${RESET}\n"

# ---------------------------------------------------------------------------
# 1. Xcode CLI Tools — provides git
# ---------------------------------------------------------------------------
if ! command -v git >/dev/null 2>&1; then
  print -P "  ${WARN} installing Xcode Command Line Tools (GUI prompt)"
  xcode-select --install 2>/dev/null || true
  while ! command -v git >/dev/null 2>&1; do sleep 0.5; done
fi
print -P "  ${OK} xcode cli tools"

# ---------------------------------------------------------------------------
# 2. Touch ID for sudo — one password prompt now, biometric forever after.
#    Without this, brew's sudo asks hang silently because the pipe has no TTY.
# ---------------------------------------------------------------------------
if ! sudo grep -q pam_tid /etc/pam.d/sudo_local 2>/dev/null; then
  print -P "  ${WARN} enabling Touch ID for sudo (enter password once)"
  sudo sh -c 'printf "auth       sufficient     pam_tid.so\n" > /etc/pam.d/sudo_local'
fi
print -P "  ${OK} touchid sudo"

# ---------------------------------------------------------------------------
# 3. Homebrew — NONINTERACTIVE skips the "press RETURN" prompt; brew's sudo
#    calls now resolve via Touch ID GUI dialog.
# ---------------------------------------------------------------------------
if ! command -v brew >/dev/null 2>&1; then
  print -P "  ${WORK} installing Homebrew"
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
if [[ -d /opt/homebrew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
else
  eval "$(/usr/local/bin/brew shellenv)"
fi
print -P "  ${OK} homebrew"

# ---------------------------------------------------------------------------
# 4. Install gh + mise immediately — the rest of bootstrap needs both. brew
#    bundle (in task converge later) will see them already there and skip.
# ---------------------------------------------------------------------------
print -P "  ${WORK} installing gh + mise"
brew install --quiet gh mise
print -P "  ${OK} gh + mise"

# ---------------------------------------------------------------------------
# 5. GitHub auth — exporting GITHUB_TOKEN now means mise can fetch version
#    metadata from GitHub without rate-limiting during the rest of bootstrap.
# ---------------------------------------------------------------------------
if ! gh auth status &>/dev/null; then
  print -P "  ${WARN} run ${BOLD}gh auth login${RESET} in another terminal"
  while ! gh auth status &>/dev/null; do sleep 0.5; done
fi
export GITHUB_TOKEN="$(gh auth token 2>/dev/null)"
print -P "  ${OK} gh authed (GITHUB_TOKEN exported)"

# ---------------------------------------------------------------------------
# 6. 1Password — install app + CLI, then block until SSH agent is enabled.
#    Everything downstream (ssh git, op secrets) depends on this.
# ---------------------------------------------------------------------------
print -P "  ${WORK} installing 1Password (app + CLI)"
brew install --cask --quiet 1password 1password-cli

sock="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
if [[ ! -S "$sock" ]]; then
  print -P "  ${WARN} open 1Password → Settings → Developer, then enable:"
  print -P "         • ${BOLD}SSH Agent${RESET}"
  print -P "         • ${BOLD}Connect with 1Password CLI${RESET}"
  while [[ ! -S "$sock" ]]; do sleep 0.5; done
fi
print -P "  ${OK} 1password agent ready"

# ---------------------------------------------------------------------------
# 7. Clone (or fast-forward) dotfiles to the real location
# ---------------------------------------------------------------------------
if [[ ! -d "$DOTFILES" ]]; then
  git clone https://github.com/radiosilence/dotfiles "$DOTFILES"
else
  # Force HTTPS for this fetch in case use-ssh switched the remote during a
  # previous partial run — we don't want pull blocking on SSH config that
  # hasn't been linked yet.
  git -C "$DOTFILES" -c "remote.origin.url=https://github.com/radiosilence/dotfiles" \
    pull --ff-only --quiet origin main 2>/dev/null || \
    print -P "  ${WARN} couldn't fast-forward — using existing checkout"
fi
print -P "  ${OK} dotfiles at $DOTFILES"

# ---------------------------------------------------------------------------
# 8. Install task + aube via mise. task drives `converge`; aube is the
#    npm-backend package_manager configured in mise.toml — without it,
#    `mise install` blows up on any npm: tool.
# ---------------------------------------------------------------------------
print -P "  ${WORK} installing task + aube via mise"
mise install task@latest aube@latest >/dev/null
export PATH="$HOME/.local/share/mise/shims:$PATH"
print -P "  ${OK} task + aube installed via mise"

# ---------------------------------------------------------------------------
# 9. Hand off — task converge handles everything else (parallel from here)
# ---------------------------------------------------------------------------
print -P "  ${OK} bootstrap done — handing off to Taskfile\n"

cd "$DOTFILES"
task converge
