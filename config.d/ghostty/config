theme = monokai-pro
background-opacity = 0.85
background-blur = 20
font-family = Geist Mono
font-size = 11
font-style = Regular
keybind = global:§=toggle_quick_terminal
quick-terminal-animation-duration = 0
macos-option-as-alt = true
keybind = alt+3=text:#
keybind = alt+2=text:€
keybind = alt+0=text:º
# pane navigation handled by tmux (C-a h/j/k/l)
# keybind = cmd+left=goto_split:left
# keybind = cmd+right=goto_split:right
# keybind = cmd+up=goto_split:top
# keybind = cmd+down=goto_split:bottom
keybind = alt+backspace=text:\x17
keybind = shift+enter=text:\n
clipboard-paste-protection = false