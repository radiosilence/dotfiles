theme = monokai-pro
background-opacity = 0.85
background-blur = 20
macos-titlebar-style = tabs
font-family = Geist Mono
font-size = 11
font-style = Regular
keybind = global:§=toggle_quick_terminal
quick-terminal-animation-duration = 0
macos-option-as-alt = true
keybind = alt+3=text:#
keybind = alt+2=text:€
keybind = alt+0=text:º
keybind = alt+minus=text:–
keybind = alt+shift+minus=text:—
keybind = alt+backspace=text:\x17
keybind = shift+enter=text:\n
clipboard-paste-protection = false

# Cmd+C → F12 (CSI \e[24~) so zellij's F12 → Copy bind triggers against zellij's selection.
keybind = cmd+c=text:\x1b[24~

# New tabs/windows always start in $HOME — don't inherit CWD from parent.
working-directory = home
window-inherit-working-directory = false
tab-inherit-working-directory = false

cursor-click-to-move = true
notify-on-command-finish = unfocused
window-save-state = always
link-previews = true
confirm-close-surface = false